# Merging lists
a = [1, 2, 3]
b = [4, 5, 6]
a.extend(b)
print(a)

a = [1, 2, 3]
b = [4, 5, 6]
c = a + b
print(c)

# Statistical operations
a = [10, 20, 30, 40]
print(sum(a))
print(min(a))
print(max(a))

# Slicing
a = [10, 20, 30, 40, 50, 60]
print(a[1:4])
print(a[:3])
print(a[3:])
print(a[-1])
print(a[-4:])
print(a[-4:-1])
